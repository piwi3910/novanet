# Dockerfile.agent — Production image for the NovaNet agent, CNI binary, and CLI.
#
# Multi-stage build with cross-compilation:
#   1. Builder stage always runs on the build platform (amd64) and cross-compiles
#      for the target architecture — no QEMU emulation needed for Go compilation.
#   2. Runtime stage uses the target platform's Alpine.

# ---------- builder (always runs on native build platform) ----------
FROM --platform=$BUILDPLATFORM golang:1.26.1-bookworm AS builder

ARG TARGETARCH
ARG TARGETOS

WORKDIR /src

# Cache module downloads.
COPY go.mod go.sum ./
RUN go mod download

# Copy source tree.
COPY . .

# Build all Go binaries with stripped debug info, cross-compiled for target.
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -ldflags="-s -w" -o /out/novanet-agent   ./cmd/novanet-agent/
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -ldflags="-s -w" -o /out/novanet-cni     ./cmd/novanet-cni/
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -ldflags="-s -w" -o /out/novanetctl      ./cmd/novanetctl/

# Download standard CNI plugins (needed for loopback) for the target architecture.
ARG CNI_PLUGINS_VERSION=v1.6.2
RUN curl -fsSL "https://github.com/containernetworking/plugins/releases/download/${CNI_PLUGINS_VERSION}/cni-plugins-linux-${TARGETARCH}-${CNI_PLUGINS_VERSION}.tgz" \
    | tar -xz -C /out ./loopback

# ---------- runtime (target platform) ----------
FROM alpine:3.21

RUN apk add --no-cache \
    ca-certificates \
    iptables \
    ip6tables \
    iproute2 \
    && addgroup -S novanet && adduser -S -G novanet novanet

# Copy binaries from builder.
COPY --from=builder /out/novanet-agent  /usr/bin/novanet-agent
COPY --from=builder /out/novanet-cni    /usr/bin/novanet-cni
COPY --from=builder /out/novanetctl     /usr/bin/novanetctl
COPY --from=builder /out/loopback       /usr/lib/cni/loopback

# Create runtime directories.
RUN mkdir -p /run/novanet && chown novanet:novanet /run/novanet

# Health check via the agent's gRPC status endpoint.
HEALTHCHECK --interval=15s --timeout=5s --retries=3 \
    CMD novanetctl status --agent-socket /run/novanet/novanet.sock >/dev/null 2>&1 || exit 1

ENTRYPOINT ["novanet-agent"]
